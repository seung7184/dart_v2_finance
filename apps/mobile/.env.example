# Mobile auth: public/client-safe values only.
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
EXPO_PUBLIC_APP_SCHEME=dart-finance

# Billing placeholders are public RevenueCat SDK keys. Billing remains out of auth scope.
EXPO_PUBLIC_REVENUECAT_APPLE_PUBLIC_KEY=appl_your_revenuecat_apple_key
EXPO_PUBLIC_REVENUECAT_GOOGLE_PUBLIC_KEY=goog_your_revenuecat_google_key
