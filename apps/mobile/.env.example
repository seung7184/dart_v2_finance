# Mobile auth: public/client-safe values only.
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
EXPO_PUBLIC_APP_SCHEME=dart-finance

# Phase 3: URL of the deployed (or local) Next.js web app.
# Used by the mobile API client to call /api/mobile/* routes.
# Android emulator local dev: http://10.0.2.2:3000
# Production: https://your-web-app.vercel.app
EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:3000

# Billing placeholders are public RevenueCat SDK keys. Billing remains out of auth scope.
EXPO_PUBLIC_REVENUECAT_APPLE_PUBLIC_KEY=appl_your_revenuecat_apple_key
EXPO_PUBLIC_REVENUECAT_GOOGLE_PUBLIC_KEY=goog_your_revenuecat_google_key
