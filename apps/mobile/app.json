      "bundleIdentifier": "com.dartfinance.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0f1117"
      },
      "package": "com.dartfinance.app"
    },
    "scheme": "dart-finance",
    "plugins": ["expo-router"]
  }
}
