{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@dart/config/typescript/react-native",
  "compilerOptions": {
    "noEmit": true,
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.d.ts", "expo-env.d.ts"],
  "exclude": ["node_modules"]
}
